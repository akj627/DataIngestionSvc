@page
@model IndexModel
@{
    ViewData["Title"] = "Clients";
}

<div class="row mb-4">
    <div class="col-12">
        <h4 class="mb-3">Ingestion</h4>
        <form method="post" enctype="multipart/form-data">
            <div class="row g-2 align-items-end mb-2">
                <div class="col-md-8">
                    <label asp-for="ZipUrl" class="form-label">ZIP URL</label>
                    <input id="urlInput" asp-for="ZipUrl" class="form-control" placeholder="https://..." />
                </div>
            </div>
            <div class="text-muted small my-2 ms-1">— or browse for a local file —</div>
            <div class="row g-2 align-items-end mb-3">
                <div class="col-md-8">
                    <label class="form-label">Local ZIP file</label>
                    <input id="fileInput" type="file" name="ZipFile" accept=".zip" class="form-control" />
                </div>
            </div>
            @if (Model.ShowInputError)
            {
                <div class="text-danger small mb-2">Provide a URL or select a local file.</div>
            }
            <button type="submit" class="btn btn-primary">Run Ingestion</button>
        </form>

        @if (Model.LastIngestionResult != null)
        {
            var r = Model.LastIngestionResult;
            <div class="alert alert-success mt-3 mb-0">
                <strong>Run #@r.RunId complete</strong> &nbsp;·&nbsp;
                @r.ClientsProcessed clients &nbsp;·&nbsp;
                @r.AccountsProcessed accounts &nbsp;·&nbsp;
                @r.HoldingsProcessed holdings &nbsp;·&nbsp;
                <span class="text-muted">@r.KnowledgeDate.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
            </div>
        }
    </div>
</div>

<hr />

<div class="d-flex align-items-center gap-3 mb-3">
    <h4 class="mb-0">Clients</h4>
    <div class="d-flex align-items-center gap-2 ms-2">
        <label class="form-label mb-0 text-muted small">Dashboard as of:</label>
        <input type="datetime-local" id="asOfPicker" class="form-control form-control-sm" style="width:200px"
               value="@Model.AsOf" />
        @if (!string.IsNullOrEmpty(Model.AsOf))
        {
            <a href="/" class="btn btn-outline-secondary btn-sm">Latest</a>
        }
    </div>
    @if (Model.Clients.Count > 0)
    {
        var runDate = Model.Clients[0].KnowledgeDate;
        <span class="text-muted small">
            @if (string.IsNullOrEmpty(Model.AsOf))
            {
                <text>— latest run · @runDate.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</text>
            }
            else
            {
                <text>— run as of @runDate.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</text>
            }
        </span>
    }
</div>

@if (Model.Clients.Count == 0)
{
    <p class="text-muted">
        @if (!string.IsNullOrEmpty(Model.AsOf))
        {
            <text>No ingestion run found on or before @Model.AsOf.</text>
        }
        else
        {
            <text>No data yet. Run ingestion above to load clients.</text>
        }
    </p>
}
else
{
    <table id="clientsTable" class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>Client ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Advisor</th>
                <th>Last Updated</th>
                <th>Knowledge Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Clients)
            {
                <tr data-url="/Clients/Accounts/@c.ClientId@(string.IsNullOrEmpty(Model.AsOf) ? "" : "?asOf=" + Uri.EscapeDataString(Model.AsOf))" style="cursor:pointer">
                    <td>@c.ClientId</td>
                    <td>@c.FirstName @c.LastName</td>
                    <td>@c.Email</td>
                    <td>@c.AdvisorId</td>
                    <td>@c.LastUpdated.LocalDateTime.ToString("yyyy-MM-dd")</td>
                    <td>@c.KnowledgeDate.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        document.getElementById('urlInput').addEventListener('input', function () {
            if (this.value) document.getElementById('fileInput').value = '';
        });
        document.getElementById('fileInput').addEventListener('change', function () {
            if (this.files.length > 0) document.getElementById('urlInput').value = '';
        });

        document.getElementById('asOfPicker').addEventListener('change', function () {
            const val = this.value;
            window.location = val ? '/?asOf=' + encodeURIComponent(val) : '/';
        });

        $(document).ready(function () {
            $('#clientsTable').DataTable({ pageLength: 10 });
            $('#clientsTable tbody').on('click', 'tr', function () {
                window.location = $(this).data('url');
            });
        });
    </script>
}
