@page
@model IndexModel
@{
    ViewData["Title"] = "Clients";
}

<div class="row mb-4">
    <div class="col-12">
        <h4 class="mb-3">Ingestion</h4>
        <form method="post" class="row g-2 align-items-end">
            <div class="col-md-8">
                <label asp-for="ZipUrl" class="form-label">ZIP URL</label>
                <input asp-for="ZipUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="ZipUrl" class="text-danger small"></span>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Run Ingestion</button>
            </div>
        </form>

        @if (Model.LastIngestionResult != null)
        {
            var r = Model.LastIngestionResult;
            <div class="alert alert-success mt-3 mb-0">
                <strong>Run #@r.RunId complete</strong> &nbsp;·&nbsp;
                @r.ClientsProcessed clients &nbsp;·&nbsp;
                @r.AccountsProcessed accounts &nbsp;·&nbsp;
                @r.HoldingsProcessed holdings &nbsp;·&nbsp;
                <span class="text-muted">@r.KnowledgeDate.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
            </div>
        }
    </div>
</div>

<hr />

<h4 class="mb-3">
    Clients
    @if (Model.Clients.Count > 0)
    {
        <span class="text-muted fs-6 fw-normal">— latest ingestion run</span>
    }
</h4>

@if (Model.Clients.Count == 0)
{
    <p class="text-muted">No data yet. Run ingestion above to load clients.</p>
}
else
{
    <table id="clientsTable" class="table table-striped table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>Client ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Advisor</th>
                <th>Last Updated</th>
                <th>Knowledge Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Clients)
            {
                <tr data-url="/Clients/Accounts/@c.ClientId" style="cursor:pointer">
                    <td>@c.ClientId</td>
                    <td>@c.FirstName @c.LastName</td>
                    <td>@c.Email</td>
                    <td>@c.AdvisorId</td>
                    <td>@c.LastUpdated.UtcDateTime.ToString("yyyy-MM-dd")</td>
                    <td>@c.KnowledgeDate.UtcDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#clientsTable').DataTable({ pageLength: 10 });
            $('#clientsTable tbody').on('click', 'tr', function () {
                window.location = $(this).data('url');
            });
        });
    </script>
}
